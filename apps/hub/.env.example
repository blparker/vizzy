# Neon Postgres
DATABASE_URL=postgres://user:pass@host.neon.tech/dbname?sslmode=require

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
