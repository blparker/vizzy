{
    "name": "@vizzyjs/core",
    "version": "0.1.0",
    "description": "Render-agnostic core for vizzy: shapes, scene graph, animations, and math utilities for interactive math visualization",
    "type": "module",
    "license": "MIT",
    "author": "Bryan Parker",
    "homepage": "https://github.com/blparker/vizzy",
    "repository": {
        "type": "git",
        "url": "https://github.com/blparker/vizzy.git",
        "directory": "packages/core"
    },
    "bugs": {
        "url": "https://github.com/blparker/vizzy/issues"
    },
    "keywords": [
        "visualization",
        "math",
        "animation",
        "manim",
        "canvas",
        "typescript",
        "scene-graph"
    ],
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch"
    }
}
