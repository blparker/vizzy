{
    "name": "vizzyjs",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.15.0",
    "scripts": {
        "build": "pnpm -r build",
        "test": "vitest",
        "lint": "eslint packages/",
        "typecheck": "tsc -b",
        "playground": "pnpm --filter @vizzyjs/playground dev",
        "docs": "pnpm --filter @vizzyjs/docs dev",
        "hub": "pnpm --filter @vizzyjs/hub dev",
        "release": "./scripts/release.sh"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "eslint": "^10.2.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": ">=22",
        "pnpm": ">=10"
    }
}
