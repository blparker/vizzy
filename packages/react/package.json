{
    "name": "@vizzyjs/react",
    "version": "0.1.1",
    "description": "React bindings for vizzy: a useScene hook for rendering vizzy scenes in React components",
    "type": "module",
    "license": "MIT",
    "author": "Bryan Parker",
    "homepage": "https://github.com/blparker/vizzy",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/blparker/vizzy.git",
        "directory": "packages/react"
    },
    "bugs": {
        "url": "https://github.com/blparker/vizzy/issues"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "visualization",
        "math",
        "animation",
        "manim",
        "canvas",
        "typescript",
        "react",
        "hook"
    ],
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch"
    },
    "devDependencies": {
        "@types/react": "^19.2.14",
        "@vizzyjs/core": "workspace:*",
        "@vizzyjs/renderer-canvas": "workspace:*",
        "react": "^19.2.5"
    },
    "peerDependencies": {
        "@vizzyjs/core": "^0.1.1",
        "@vizzyjs/renderer-canvas": "^0.1.1",
        "react": ">=19"
    }
}
